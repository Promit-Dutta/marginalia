# ════════════════════════════════════════════════════════════════
# .gitignore — Marginalia
# ════════════════════════════════════════════════════════════════
# This file tells Git what NOT to track.
#
# IMPORTANT: posts.html and feed.xml are GENERATED by
#   python server.py --build
# and MUST be committed — GitHub Pages needs them as static files.
# They are intentionally NOT listed here.
# ════════════════════════════════════════════════════════════════


# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/

# ── Virtual environments ──────────────────────────────────────────
# Never commit a venv — it contains thousands of files and is
# machine-specific. Recreate with: pip install flask
.venv/
venv/
env/
ENV/
.env/
env.bak/
venv.bak/
.python-version

# ── Environment variables and secrets ────────────────────────────
# If you ever add a .env file for API keys, tokens, etc.
.env
.env.local
.env.*.local
*.env
secrets.py
config_local.py

# ── Flask session / cache ─────────────────────────────────────────
instance/
flask_session/
.webassets-cache

# ── Drafts inside posts/ ─────────────────────────────────────────
# Files starting with _ are already skipped by server.py's get_posts(),
# so they won't appear in the listing — but they would still be pushed
# to GitHub (publicly visible) unless listed here.
# Uncomment the line below if you want draft posts to stay local:
# posts/_*.html

# Backup / temp copies of posts
posts/*.bak
posts/*.tmp
posts/*.draft
posts/*.orig

# ── OS generated files ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/

# ── Editor and IDE ────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist
Session.vim

# Emacs
\#*\#
.\#*
*.elc

# ── Logs ──────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt
pip-delete-this-directory.txt

# ── Node (not used, but in case you ever add tooling) ────────────
node_modules/
.npm
.yarn/

# ── Miscellaneous ─────────────────────────────────────────────────
*.bak
*.tmp
*.orig
*.rej
.cache/
.history/
.sass-cache/

# ── Git conflict leftovers ────────────────────────────────────────
*.BACKUP.*
*.BASE.*
*.LOCAL.*
*.REMOTE.*
*_BACKUP_*.html
*_BASE_*.html
*_LOCAL_*.html
*_REMOTE_*.html