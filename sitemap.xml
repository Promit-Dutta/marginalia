<?xml version="1.0" encoding="UTF-8"?>
<!--
  sitemap.xml — Marginalia
  ════════════════════════════════════════════════════════════════
  Submit this file to Google Search Console after deployment:
    1. Go to search.google.com/search-console
    2. Add your site (verify via HTML file or DNS)
    3. Go to Sitemaps → paste your sitemap URL → Submit

  KEEPING THIS UP TO DATE:
    Add a new <url> block every time you publish a post.
    The <lastmod> date tells Google when content changed.
    <changefreq> and <priority> are hints, not commands.

  Replace YOUR_DOMAIN throughout with your actual domain,
  e.g. Promit-Dutta.github.io or marginalia.xyz
  ════════════════════════════════════════════════════════════════
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <!-- Homepage -->
  <url>
    <loc>https://promit-dutta.github.io/marginalia/</loc>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Posts listing page -->
  <url>
    <loc>https://promit-dutta.github.io/marginalia/posts.html</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- Marginal Notes journal — update <lastmod> each time you add an entry -->
  <url>
    <loc>https://promit-dutta.github.io/marginalia/notes.html</loc>
    <lastmod>2026-04-20</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- Comment policy — rarely changes -->
  <url>
    <loc>https://promit-dutta.github.io/marginalia/static/comment-policy.html</loc>
    <changefreq>yearly</changefreq>
    <priority>0.2</priority>
  </url>

  <!--
    ── INDIVIDUAL POSTS ──────────────────────────────────────────
    Add one <url> block per post when you publish.
    Copy this pattern and paste it below:

    <url>
      <loc>https://promit-dutta.github.io/marginalia/posts/your-post-slug.html</loc>
      <lastmod>YYYY-MM-DD</lastmod>
      <changefreq>never</changefreq>
      <priority>0.8</priority>
    </url>
  -->

</urlset>